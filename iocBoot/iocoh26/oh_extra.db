record(seq, "$(P)UR:ClearFault") {
    field(DOL0, 1)
    field(LNK0, "$(P)UR:Dashboard:UnlockProtectiveStop.PROC")
    field(DLY1, 1.0)
    field(DOL1, 1)
    field(LNK1, "$(P)UR:Control:ReuploadControlScript.PROC")
}

record(calcout, "$(P)UR:disconnect_on_scan_start_") {
    field(INPA, "$(P)scan1.BUSY CP")
    field(INPB, "$(P)scan2.BUSY CP")
    field(CALC, "A || B")
    field(OOPT, "Transition To Non-zero")
    field(OUT, "$(P)UR:Control:Disconnect.PROC")
}

record(calcout, "$(P)UR:connect_on_scan_stop_") {
    field(INPA, "$(P)scan1.BUSY CP")
    field(INPB, "$(P)scan2.BUSY CP")
    field(CALC, "A=0 && B=0")
    field(OOPT, "Transition To Non-zero")
    field(OUT, "$(P)UR:Control:Reconnect.PROC")
}

record(seq, "$(P)StartScan") {
    field(DOL0, 1)
    field(LNK0, "$(P)UR:wristcam:Acquire PP")
    field(DOL1, 0)
    field(LNK1, "$(P)UR:JPEG1:FileNumber.VAL PP")
    field(DOL2, 1)
    field(LNK2, "$(P)scan1.EXSC")
}
